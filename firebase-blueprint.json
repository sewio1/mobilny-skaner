{
  "collections": [
    {
      "name": "users",
      "fields": [
        { "name": "email", "type": "string" },
        { "name": "role", "type": "string" }
      ],
      "rules": "allow read: if request.auth != null; allow write: if false;"
    },
    {
      "name": "sheets",
      "fields": [
        { "name": "name", "type": "string" },
        { "name": "status", "type": "string" },
        { "name": "assignedTo", "type": "string", "optional": true },
        { "name": "createdBy", "type": "string" },
        { "name": "createdAt", "type": "timestamp" }
      ],
      "rules": "allow read: if request.auth != null; allow create, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; allow update: if request.auth != null;",
      "subcollections": [
        {
          "name": "items",
          "fields": [
            { "name": "lp", "type": "string", "optional": true },
            { "name": "lokalizacja", "type": "string" },
            { "name": "kodGlowny", "type": "string" },
            { "name": "kodPomocniczy", "type": "string" },
            { "name": "nazwa", "type": "string" },
            { "name": "partia", "type": "string", "optional": true },
            { "name": "dataWaznosci", "type": "string", "optional": true },
            { "name": "sj", "type": "string" },
            { "name": "iloscSystemowa", "type": "number" },
            { "name": "licz1", "type": "number", "optional": true },
            { "name": "licz2", "type": "number", "optional": true },
            { "name": "licz3", "type": "number", "optional": true },
            { "name": "adnotacje", "type": "string", "optional": true },
            { "name": "rowNum", "type": "number", "optional": true }
          ],
          "rules": "allow read: if request.auth != null; allow create, delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; allow update: if request.auth != null;"
        }
      ]
    }
  ]
}
